<!-- Pages/PageLike.xaml -->
<Page x:Class="WpfApp1.Pages.PageLike"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="❤️ Избранные рецепты"
      Width="1200" Height="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 🏰 Заголовок страницы -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                BorderBrush="Gold"
                BorderThickness="0,0,0,1"/>

        <TextBlock Text="❤️ Избранные рецепты"
                   Grid.Row="0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"
                   FontSize="20"
                   FontWeight="Bold"/>

        <!-- 📚 СПИСОК ИЗБРАННЫХ РЕЦЕПТОВ -->
        <Grid Grid.Row="1" Margin="20,10,20,10">

            <!-- 🎭 КНОПКИ ПЕРЕКЛЮЧЕНИЯ ВИДА -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,0,10,0">

                <Button x:Name="btnListView"
                        Content="📋 Список"
                        Click="Button_Click_List"/>

                <Button x:Name="btnGridView"
                        Content="🧙 Плитка"
                        Click="Button_Click_Grid"/>

            </StackPanel>

            <!-- 📖 СПИСОК РЕЦЕПТОВ (ListView) -->
            <ListView x:Name="listProducts"
                      Margin="0,40,0,0"
                      MouseDoubleClick="listProducts_MouseDoubleClick">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- 🖼️ ИЗОБРАЖЕНИЕ РЕЦЕПТА -->
                                <Border Grid.Column="0">
                                    <Image Source="{Binding CurrentPhoto}"/>
                                </Border>

                                <!-- 📝 ИНФОРМАЦИЯ О РЕЦЕПТЕ -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding RecipeName}" FontWeight="Bold"/>
                                    <TextBlock>
                                        <Run Text="📁 Категория:"/>
                                        <Run Text="{Binding Categories.CategoryName}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="📖 Описание:"/>
                                        <Run Text="{Binding Description}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="🧙 Время приготовления:"/>
                                        <Run Text="{Binding CookingTime}"/>
                                        <Run Text="минут"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 🎭 ДЕЙСТВИЯ -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <!-- 🗑️ Удалить из избранного -->
                                    <Button x:Name="btnDelete"
                                            Tag="{Binding}"
                                            Click="btnDelete_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑️"/>
                                            <TextBlock Text="Удалить" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

            <!-- ⏰ ВИД ПЛИТКОЙ (ItemsControl) -->
            <ItemsControl x:Name="myGridView"
                          Visibility="Collapsed"
                          Margin="0,40,0,0">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8" Width="220">
                            <StackPanel>
                                <Border>
                                    <Image Source="{Binding CurrentPhoto}" Height="140" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Margin="8">
                                    <TextBlock Text="{Binding RecipeName}" FontWeight="Bold"/>
                                    <TextBlock>
                                        <Run Text="Категория:"/>
                                        <Run Text="{Binding Categories.CategoryName}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Время:"/>
                                        <Run Text="{Binding CookingTime}"/>
                                        <Run Text="мин"/>
                                    </TextBlock>
                                    <Button x:Name="btnGridDelete"
                                            Tag="{Binding}"
                                            Click="btnDelete_Click"
                                            Margin="0,8,0,0"
                                            ToolTip="Удалить из избранного">
                                        <TextBlock Text="🗑️ Удалить"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </Grid>

        <!-- 📝 НИЖНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="2"
                CornerRadius="0,0,10,10"
                Margin="20,0,20,10">
            <Grid>

                <!-- 📊 Счётчик -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="20,0,0,0">
                    <TextBlock x:Name="tbCounter"
                               Text="❤️ Загрузка избранного..."/>
                </StackPanel>

                <!-- 🔙 Кнопка назад -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <Button x:Name="btnBack"
                            Content="◀ Назад к рецептам"
                            Width="160"
                            Height="35"
                            Margin="10,0"
                            Click="btnBack_Click"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>
