<Page x:Class="WpfApp1.Pages.PageShagi"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Шаги приготовления">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" CornerRadius="10" Margin="20,10,20,10">
            <TextBlock x:Name="tbTitle"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontFamily="Segoe Script"
                       FontWeight="Bold"/>
        </Border>

        <!-- Основная часть -->
        <Grid Grid.Row="1" Margin="20,0,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: список шагов -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Панель добавления шага -->
                <Border Grid.Row="0" Margin="0,0,0,10" Padding="10" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#55FFFFFF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StepDescBox"
                                 Grid.Column="0"
                                 Height="34"
                                 Padding="6,5"
                                 FontSize="13"
                                 Margin="0,0,10,0"
                                 FontFamily="Segoe UI"/>
                        <Button Grid.Column="1"
                                Content="Добавить шаг"
                                Height="34"
                                FontFamily="Segoe Script"
                                FontSize="12"
                                Click="btnAddStep_Click"/>
                    </Grid>
                </Border>

                <!-- Список шагов -->
                <ListView x:Name="StepsList"
                          Grid.Row="1"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="6"
                                    BorderThickness="1" BorderBrush="#44FFFFFF"
                                    Background="#22FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Номер шага -->
                                    <Border Grid.Column="0" Width="28" Height="28"
                                            CornerRadius="14" Background="#88FFFFFF"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StepNumber}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="13"/>
                                    </Border>

                                    <!-- Описание -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StepDescription}"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               FontFamily="Segoe UI"
                                               VerticalAlignment="Center"
                                               Margin="8,0"/>

                                    <!-- Кнопки -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="↑" Tag="{Binding}"
                                                Width="28" Height="28" Margin="2,0"
                                                FontSize="14"
                                                Click="btnMoveUp_Click"
                                                ToolTip="Переместить выше"/>
                                        <Button Content="↓" Tag="{Binding}"
                                                Width="28" Height="28" Margin="2,0"
                                                FontSize="14"
                                                Click="btnMoveDown_Click"
                                                ToolTip="Переместить ниже"/>
                                        <Button Content="✕" Tag="{Binding}"
                                                Width="28" Height="28" Margin="2,0"
                                                FontSize="12"
                                                Click="btnDeleteStep_Click"
                                                ToolTip="Удалить"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Правая колонка: превью -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Предпросмотр:"
                           FontFamily="Segoe Script"
                           FontSize="14"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"/>
                <Border BorderBrush="Gray" BorderThickness="1"
                        CornerRadius="8" Width="240" Height="200"
                        HorizontalAlignment="Center">
                    <Image x:Name="RecipeImage"
                           Stretch="UniformToFill"
                           ClipToBounds="True"/>
                </Border>
                <TextBlock x:Name="tbStepCount"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe Script"
                           FontSize="13"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Нижняя панель кнопок -->
        <Border Grid.Row="2" CornerRadius="0,0,10,10" Margin="20,0,20,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button Content="← Назад к рецепту"
                        Width="160" Height="35" Margin="10,0"
                        FontFamily="Segoe Script" FontSize="13"
                        Click="btnBack_Click"/>
                <Button Content="✅ Сохранить"
                        Width="140" Height="35" Margin="10,0"
                        FontFamily="Segoe Script" FontSize="13"
                        Click="btnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
